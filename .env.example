# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Database
POSTGRES_USER=commander
POSTGRES_PASSWORD=commander
POSTGRES_DB=commander
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# CORS
CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (Sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Google Sheets OAuth
GOOGLE_SHEETS_REDIRECT_URI=http://localhost:8000/api/v1/sheets/callback

# Encryption key for OAuth tokens stored in DB
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Twilio voice number (e.g. +14155238886 — without 'whatsapp:' prefix)
TWILIO_VOICE_FROM=

# ElevenLabs TTS
ELEVENLABS_API_KEY=
# Optional: override the default voice (Rachel)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Public backend URL — must be reachable by Twilio (use ngrok URL in dev)
BACKEND_URL=https://xxxx.ngrok-free.app

# ngrok (exposes local API to internet for Twilio webhooks)
# Get authtoken from: https://dashboard.ngrok.com/authtokens
NGROK_AUTHTOKEN=
