# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
APP_ENV=development          # "development" or "production"
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Database (required)
# ──────────────────────────────────────────────
POSTGRES_USER=commander
POSTGRES_PASSWORD=commander  # CHANGE in production!
POSTGRES_DB=commander
POSTGRES_HOST=postgres       # Docker service name
POSTGRES_PORT=5432

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_HOST=redis             # Docker service name
REDIS_PORT=6379
REDIS_PASSWORD=              # Optional: set a password (recommended in production)

# ──────────────────────────────────────────────
# JWT / Security (required in production)
# ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for OAuth tokens stored in DB (required in production)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ──────────────────────────────────────────────
# Public URLs
# ──────────────────────────────────────────────
# Backend URL reachable from the internet (Twilio webhooks, OAuth callbacks).
# Dev: ngrok URL (e.g. https://xxxx.ngrok-free.dev)
# Prod: your domain (e.g. https://commander.example.com)
BACKEND_URL=https://xxxx.ngrok-free.app

# Frontend URL — used for OAuth redirect after login
# Dev: http://localhost:4200 | Prod: https://commander.example.com
FRONTEND_URL=http://localhost:4200

# CORS allowed origins (JSON array)
# Prod: ["https://commander.example.com"]
CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]

# ──────────────────────────────────────────────
# Google OAuth (required in production)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override auto-derived redirect URIs (derived from BACKEND_URL)
# GOOGLE_REDIRECT_URI=https://commander.example.com/api/v1/auth/google/callback
# GOOGLE_SHEETS_REDIRECT_URI=https://commander.example.com/api/v1/sheets/callback

# ──────────────────────────────────────────────
# Twilio (WhatsApp + Voice)
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Voice number (e.g. +14155238886 — without 'whatsapp:' prefix)
TWILIO_VOICE_FROM=

# ──────────────────────────────────────────────
# ElevenLabs TTS
# ──────────────────────────────────────────────
ELEVENLABS_API_KEY=
# Optional: override the default voice
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ──────────────────────────────────────────────
# Dev only — ngrok (not needed in production)
# ──────────────────────────────────────────────
# Get authtoken from: https://dashboard.ngrok.com/authtokens
NGROK_AUTHTOKEN=
NGROK_DOMAIN=xxxx.ngrok-free.dev

# ──────────────────────────────────────────────
# Production only — Caddy / Domain
# ──────────────────────────────────────────────
# Your domain for automatic HTTPS via Let's Encrypt
# DOMAIN=commander.example.com
